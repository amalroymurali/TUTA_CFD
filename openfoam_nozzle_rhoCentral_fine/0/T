FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;

boundaryField
{
    SOLID_WALL
    {
        type        zeroGradient;
    }

    INLET
    {
        type        fixedValue;
        value       uniform 300;
    }

    OUTLET
    {
        type        zeroGradient;
    }

    FARFIELD
    {
        type        fixedValue;
        value       uniform 300;
    }

    AXIALSYMMETRY
    {
        type        symmetryPlane;
    }

    FRONT
    {
        type        empty;
    }

    BACK
    {
        type        empty;
    }
}
