FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      nut;
}

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    SOLID_WALL
    {
        type        nutkWallFunction;
        value       uniform 0;
    }

    INLET
    {
        type        calculated;
        value       uniform 0;
    }

    OUTLET
    {
        type        calculated;
        value       uniform 0;
    }

    FARFIELD
    {
        type        calculated;
        value       uniform 0;
    }

    AXIALSYMMETRY
    {
        type        symmetryPlane;
    }

    FRONT
    {
        type        empty;
    }

    BACK
    {
        type        empty;
    }
}
