FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 101325;

boundaryField
{
    SOLID_WALL
    {
        type        zeroGradient;
    }

    INLET
    {
        type        fixedValue;
        value       uniform 5e6;
    }

    OUTLET
    {
        type        fixedValue;
        value       uniform 1e5;
    }

    FARFIELD
    {
        type        fixedValue;
        value       uniform 101325;
    }

    AXIALSYMMETRY
    {
        type        symmetryPlane;
    }

    FRONT
    {
        type        empty;
    }

    BACK
    {
        type        empty;
    }
}
