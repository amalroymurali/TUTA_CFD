FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

solver          shockFluid;

startFrom       latestTime;
startTime       0;

stopAt          endTime;
endTime         0.002;

deltaT          1e-7;
adjustTimeStep  yes;
maxCo           0.5;
maxDeltaT       1e-5;

writeControl    timeStep;
writeInterval   500;

purgeWrite      5;
writeFormat     ascii;
writePrecision  8;
writeCompression off;

timeFormat      general;
timePrecision   6;

runTimeModifiable true;
